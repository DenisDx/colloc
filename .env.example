# Public endpoint
DOMAIN=example.local

# TLS certificate path on host
EXTERNAL_CERTIFICATE=/etc/letsencrypt
LETSENCRYPT_EMAIL=admin@example.local

# Persistent paths inside repository
DATA_ROOT=./data
CONFIG_ROOT=./config
LOG_ROOT=./logs

# Nginx bind and ports
NGINX_HTTP_BIND=0.0.0.0
NGINX_HTTP_PORT=6080
NGINX_HTTPS_BIND=0.0.0.0
NGINX_HTTPS_PORT=6443
NGINX_CLIENT_MAX_BODY_SIZE=64m

# Web UI auth
WEBUI_AUTH_ENABLED=true
WEBUI_ADMIN_USERNAME=admin
WEBUI_ADMIN_PASSWORD_HASH=

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# System startup and model preloading
AUTOLOAD=false
AUTOLOAD_LLM_RELOAD_INTERVAL_SEC=180

# System reset API backend:
# - hook: POST to SYSTEM_RESET_HOOK_URL (recommended; host-side restarter)
# - command: run SYSTEM_RESET_COMMAND inside backend container
SYSTEM_RESET_MODE=command
SYSTEM_RESET_HOOK_URL=
# Hook listener bind host on the machine running colloc.service
SYSTEM_RESET_HOOK_BIND_HOST=0.0.0.0
# Services to keep running on Stop services action
SYSTEM_SERVICE_CONTROL_KEEP_SERVICES=gateway,webui-backend,redis
# Leave empty to auto-build: core + active TTS dependency profiles
SYSTEM_RESET_COMMAND=
# Used only when SYSTEM_RESET_MODE=command and Stop services button is clicked
SYSTEM_STOP_SERVICES_COMMAND=
# Used only when SYSTEM_RESET_MODE=command and Start services button is clicked
SYSTEM_START_SERVICES_COMMAND=
SYSTEM_RESET_CWD=/app

# LLM routing
LLM_REQUEST_TIMEOUT_SEC=60
LLM_HEALTHCHECK_INTERVAL_SEC=100

# vLLM as a primary provider for LLM routing
LLM_PROVIDER_PRIMARY=vllm
LLM_PROVIDER_PRIMARY_BASE_URL=http://llm-host.example.local:8000
LLM_PROVIDER_PRIMARY_MODEL=Qwen/Qwen2.5-7B-Instruct

# Ollama: fallback provider for LLM routing
LLM_PROVIDER_FALLBACK=ollama
LLM_PROVIDER_FALLBACK_BASE_URL=http://ollama-host.example.local:11434
LLM_PROVIDER_FALLBACK_MODEL=qwen2.5:7b

# STT
STT_PROVIDER_PRIMARY=faster_whisper
STT_PROVIDER_FALLBACK=external
STT_MODEL=large-v3-turbo
# STT device: cpu | cuda
STT_DEVICE=cpu
# Compute type: int8 works on all GPUs (incl. Pascal/GTX 10xx); float16/int8_float16 requires Turing+ (RTX 20xx+)
STT_COMPUTE_TYPE=int8
STT_BEAM_SIZE=5
STT_EXTERNAL_URL=
STT_PUBLISH_PORT=6020
STT_PUBLISH_ENABLED=false

# TTS — per-language routing
# Format: TTS_<LANG>_<PRIMARY|FALLBACK>_<PROVIDER|VOICE|PORT|URL>
# Providers: piper, kokoro, silero, external
# Only containers whose provider name appears here will be needed.
# For piper, one container per language (piper-en, piper-ru, ...);
# kokoro and silero are shared multi-language containers.
TTS_EN_PRIMARY_PROVIDER=piper
TTS_EN_PRIMARY_VOICE=en_US-lessac-medium
TTS_EN_PRIMARY_PORT=6010
TTS_EN_FALLBACK_PROVIDER=kokoro
TTS_EN_FALLBACK_VOICE=en_US_Emily

TTS_RU_PRIMARY_PROVIDER=piper
TTS_RU_PRIMARY_VOICE=ru_RU-irina-medium
TTS_RU_PRIMARY_PORT=6011
TTS_RU_FALLBACK_PROVIDER=silero
TTS_RU_FALLBACK_VOICE=ru_v3

# Infrastructure ports (used by shared containers)
KOKORO_PORT=6030
SILERO_PORT=6040

# Piper model download device
PIPER_DEVICE=cpu

# Optional default preload voice inside kokoro container
KOKORO_VOICE=en_US_Emily

TTS_EXTERNAL_URL=
TTS_PUBLISH_PORT=6031
TTS_PUBLISH_ENABLED=false

# Local audio mode
LOCAL_AUDIO_ENABLED=false
AUDIO_INPUT_DEVICE=default
AUDIO_OUTPUT_DEVICE=default
AUDIO_ECHO_CANCELLATION=true

# SIP / telephony
SIP_ENABLED=false
SIP_SERVICE_PORT=8004
SIP_ROLE=ai_scripts/test.md
SIP_GREETINGS=ai_scripts/greetings.md
SIP_MAX_SILENCE=30
SIP_MAX_DURATION=600
SIP_DEFAULT_LANGUAGE=ru
SIP_MEDIA_HOST=sip-service
SIP_MEDIA_PORT_START=6900
SIP_MEDIA_PORT_END=6999
SIP_VAD_THRESHOLD=450
SIP_BARGE_IN_THRESHOLD=700
SIP_UTTERANCE_MIN_MS=350
SIP_UTTERANCE_END_SILENCE_MS=850
SIP_VAD_ADAPTIVE_DECAY=0.01
SIP_VAD_ADAPTIVE_RECOVERY=0.02
SIP_VAD_ADAPTIVE_MIN_FACTOR=0.45
SIP_BARGE_ADAPTIVE_MIN_FACTOR=0.45

ASTERISK_PJSIP_PORT=6060
ASTERISK_RTP_START=6700
ASTERISK_RTP_END=6800
ASTERISK_SIP_SERVICE_URL=http://sip-service:${SIP_SERVICE_PORT}
ASTERISK_HTTP_URL=http://asterisk:8088/ari
ASTERISK_ARI_APP=colloc-call-handler
ASTERISK_ARI_USER=colloc
ASTERISK_ARI_PASSWORD=change-me

# Telegram bot
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_ID=

# Tools service
TOOLS_ENABLED=true

# Web search (TOOLS_WEBSEARCH_PROVIDER: brave | duckduckgo; default: brave)
TOOLS_WEBSEARCH_ENABLED=true
TOOLS_WEBSEARCH_PROVIDER=brave
TOOLS_WEBSEARCH_BRAVE_KEY=

# URL fetch tool
TOOLS_FETCH_ENABLED=true

# Image search (reuses TOOLS_WEBSEARCH_BRAVE_KEY for Brave Images; falls back to search URL)
TOOLS_GET_IMAGE_ENABLED=true

# Weather (TOOLS_WEATHER_PROVIDER: wttr | openweathermap; default: wttr — no key needed)
TOOLS_WEATHER_ENABLED=true
TOOLS_WEATHER_PROVIDER=wttr
TOOLS_WEATHER_OWM_KEY=

# Agent bridge: call external OpenAI-compatible agent
TOOLS_AGENT_BRIDGE_ENABLED=false
TOOLS_AGENT_BRIDGE_URL=
TOOLS_AGENT_BRIDGE_MODEL=
TOOLS_AGENT_BRIDGE_API_KEY=

# SIP call-control tools (hangup, transfer) — requires TOOLS_SIP_ENABLED=true
TOOLS_SIP_ENABLED=false
